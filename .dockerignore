# ============================================================================
# Docker 构建时忽略的文件和目录
# ============================================================================
# 这个文件定义了在 docker build 时应该被忽略的文件和目录
# 可以显著减少构建上下文的大小，加快构建速度

# ============================================================================
# 版本控制系统
# ============================================================================
.git
.gitignore
.gitattributes
.github

# ============================================================================
# 包管理器和依赖
# ============================================================================
node_modules
npm-debug.log
yarn-error.log
pnpm-debug.log
.pnpm-store

# ============================================================================
# 环境和配置
# ============================================================================
.env
.env.local
.env.*.local
.env.production.local

# ============================================================================
# IDE 和编辑器
# ============================================================================
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# ============================================================================
# 构建产物（这些会在 Docker 构建中重新生成）
# ============================================================================
dist
build
.next
out
coverage

# ============================================================================
# 日志和临时文件
# ============================================================================
logs
*.log
tmp
temp
.cache
.manus-logs

# ============================================================================
# 开发工具和测试
# ============================================================================
.vitest
.vite
.turbo
.eslintcache
.stylelintcache

# ============================================================================
# Docker 和容器相关
# ============================================================================
docker-compose.override.yml
.dockerignore
Dockerfile

# ============================================================================
# CI/CD
# ============================================================================
.github/workflows
.gitlab-ci.yml
.circleci
Jenkinsfile

# ============================================================================
# 其他
# ============================================================================
README.md
LICENSE
CHANGELOG.md
.editorconfig
.prettierrc
tsconfig.json
vite.config.ts
vitest.config.ts
drizzle.config.ts

# ============================================================================
# 大型文件
# ============================================================================
*.tar.gz
*.zip
*.rar
*.7z
*.iso

# ============================================================================
# 数据库文件
# ============================================================================
*.db
*.sqlite
*.sqlite3
data.db

# ============================================================================
# 备份文件
# ============================================================================
*.bak
*.backup
*.old
*.orig
