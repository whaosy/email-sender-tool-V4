# ============================================================================
# 环境变量配置示例
# ============================================================================
# 复制此文件为 .env 并根据实际情况修改
# 
# 说明：
# - 不要将 .env 文件提交到版本控制系统
# - 生产环境中所有敏感信息应该通过环境变量或密钥管理系统注入
# - 默认值已提供，但建议根据实际需求修改
# ============================================================================

# ============================================================================
# 应用配置
# ============================================================================

# Node.js 环境
NODE_ENV=production

# 应用端口
PORT=3000

# 应用标题
VITE_APP_TITLE=邮件自动发送系统

# 应用 ID
VITE_APP_ID=email-sender-tool

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# 时区
TZ=Asia/Shanghai

# ============================================================================
# 数据库配置
# ============================================================================

# MySQL 连接字符串
# 格式：mysql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=mysql://email_user:email_password@localhost:3306/email_sender_db

# 或者分别配置各个参数
DB_HOST=localhost
DB_PORT=3306
DB_USER=email_user
DB_PASSWORD=email_password
DB_NAME=email_sender_db

# 数据库连接池配置
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================================================
# 认证配置
# ============================================================================

# JWT 密钥（用于会话管理）
# 生成方法：openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345678

# JWT Token 过期时间（单位：秒）
JWT_EXPIRES_IN=86400

# ============================================================================
# SMTP 邮件配置
# ============================================================================

# 默认 SMTP 主机
SMTP_HOST=smtp.gmail.com

# 默认 SMTP 端口
SMTP_PORT=587

# SMTP 加密类型 (none, tls, ssl)
SMTP_ENCRYPTION=tls

# 默认发件人邮箱
SMTP_FROM_EMAIL=noreply@example.com

# 默认发件人名称
SMTP_FROM_NAME=系统自动

# SMTP 用户名
SMTP_USERNAME=your-email@gmail.com

# SMTP 密码或授权码
SMTP_PASSWORD=your-app-password

# ============================================================================
# 文件上传配置
# ============================================================================

# 最大上传文件大小（单位：字节）
MAX_UPLOAD_SIZE=52428800

# 允许的文件类型
ALLOWED_FILE_TYPES=.xlsx,.xls,.csv

# ============================================================================
# 邮件发送配置
# ============================================================================

# 单次批量发送的最大邮件数
MAX_BATCH_SIZE=100

# 邮件发送超时时间（单位：毫秒）
MAIL_TIMEOUT=30000

# 邮件重试次数
MAIL_RETRY_COUNT=3

# ============================================================================
# 定时任务配置
# ============================================================================

# 是否启用定时任务
ENABLE_SCHEDULED_JOBS=true

# 定时任务检查间隔（单位：秒）
SCHEDULED_JOB_CHECK_INTERVAL=60

# ============================================================================
# 日志配置
# ============================================================================

# 日志文件路径
LOG_FILE_PATH=./logs/app.log

# 日志最大文件大小（单位：字节）
LOG_MAX_SIZE=10485760

# 日志最大保留文件数
LOG_MAX_FILES=10

# ============================================================================
# 安全配置
# ============================================================================

# CORS 允许的源
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# 是否启用 HTTPS
ENABLE_HTTPS=false

# HTTPS 证书路径（如果启用 HTTPS）
HTTPS_CERT_PATH=/app/ssl/cert.pem

# HTTPS 密钥路径（如果启用 HTTPS）
HTTPS_KEY_PATH=/app/ssl/key.pem

# ============================================================================
# 调试配置
# ============================================================================

# 是否启用调试模式
DEBUG=false

# 是否启用详细日志
VERBOSE_LOG=false

# ============================================================================
# 其他配置
# ============================================================================

# 应用版本
APP_VERSION=1.0.0

# 应用描述
APP_DESCRIPTION=邮件自动发送系统 - 支持 SMTP 配置、Excel 导入、模板管理

# ============================================================================
# Docker Compose 特定配置
# ============================================================================

# MySQL root 密码
MYSQL_ROOT_PASSWORD=root_password

# MySQL 数据库名
MYSQL_DATABASE=email_sender_db

# MySQL 用户名
MYSQL_USER=email_user

# MySQL 用户密码
MYSQL_PASSWORD=email_password

# MySQL 端口
MYSQL_PORT=3306
